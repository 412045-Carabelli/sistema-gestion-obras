        [{ "node": "Preparar Payload Gemini", "type": "main", "index": 0 }],
        []
      ]
    },
    "Preparar Payload Gemini": {
      "main": [
        [{ "node": "Analizar con Gemini", "type": "main", "index": 0 }]
      ]
    },
    "Analizar con Gemini": {
      "main": [
        [{ "node": "Extraer Respuesta", "type": "main", "index": 0 }]
      ]
    },
    "Extraer Respuesta": {
      "main": [
        [{ "node": "Enviar Echo WA", "type": "main", "index": 0 }]
      ]
    }
  },
