      "id": "node-05",
      "name": "Descargar Audio",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1120, 200]
    },
    {
      "parameters": {
        "jsCode": "// Convertir audio binario a base64 y preparar payload Gemini\nconst buffer = await this.helpers.getBinaryDataBuffer(items[0], 'audioData');\nconst base64 = buffer.toString('base64');\nconst mimeType = (items[0].binary?.audioData?.mimeType || 'audio/ogg').split(';')[0].trim();\n\n// Recuperar datos del mensaje (sobreviven al nodo de descarga binaria)\nconst msgData = $('Extraer Datos').first().json;\n\nreturn [{\n  json: {\n    from: msgData.from,\n    phoneNumberId: msgData.phoneNumberId,\n    geminiPayload: {\n      contents: [{\n        parts: [\n          {\n            inlineData: {\n              mimeType,\n              data: base64\n            }\n          },\n          {\n            text: 'Transcribe este audio. Responde SOLO con la transcripción, sin comentarios adicionales.'\n          }\n        ]\n      }]\n    }\n  }\n}];"
      },
      "id": "node-06",
      "name": "Preparar Request Gemini",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 200]
    },
    {
      "parameters": {
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key={{ $vars.GEMINI_API_KEY }}",
        "method": "POST",
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonParameters": "={{ JSON.stringify($json.geminiPayload) }}",
        "options": {}
      },
      "id": "node-07",
      "name": "Transcribir con Gemini",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1560, 200]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "r1",
              "name": "transcripcion",
              "value": "={{ $json.candidates?.[0]?.content?.parts?.[0]?.text ?? 'No se pudo transcribir el audio.' }}",
              "type": "string"
            },
            {
              "id": "r2",
              "name": "from",
              "value": "={{ $('Preparar Request Gemini').first().json.from }}",
              "type": "string"
            },
            {
              "id": "r3",
              "name": "phoneNumberId",
              "value": "={{ $('Preparar Request Gemini').first().json.phoneNumberId }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "node-08",
