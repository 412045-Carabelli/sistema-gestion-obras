        "url": "=https://graph.facebook.com/v18.0/{{ $json.phoneNumberId }}/messages",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $vars.WHATSAPP_API_TOKEN }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "keypairs",
        "bodyParameters": {
          "parameters": [
            { "name": "messaging_product", "value": "whatsapp" },
            { "name": "to", "value": "={{ $json.from }}" },
            { "name": "type", "value": "text" },
            {
              "name": "text",
              "value": "={{ JSON.stringify({ body: '📝 *Transcripción:*\\n\\n' + $json.transcripcion }) }}"
            }
          ]
        },
        "options": {}
      },
