        "options": {}
      },
      "id": "webhook_meta",
      "name": "Webhook Meta Business API",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.0,
      "position": [100, 100]
    },
    {
      "parameters": {
        "jsCode": "// Verificar token de webhook Meta\n\nif ($request.method === 'GET') {\n  // Setup del webhook\n  const verify_token = $request.query.hub_verify_token;\n  const challenge = $request.query.hub_challenge;\n  \n  if (verify_token === $env.META_VERIFY_TOKEN) {\n    return [\n      { json: { body: challenge } }\n    ];\n  } else {\n    throw new Error('Invalid verify token');\n  }\n}\n\n// POST: procesar mensaje\nconst data = $input.first();\nconst payload = data.body;\n\nreturn [\n  {\n    json: {\n      is_post: true,\n      payload: payload,\n      has_messages: payload?.entry?.[0]?.changes?.[0]?.value?.messages?.length > 0\n    }\n  }\n];"
      },
      "id": "verify_token",
      "name": "Verificar Token + Validar",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2.0,
      "position": [300, 100]
    },
    {
      "parameters": {
        "conditions": {
          "nodes": [
            {
              "name": "¿Es POST?",
              "type": "filter",
              "value1": "={{ $node['Verificar Token + Validar'].json.is_post }}",
              "value2": "true"
            }
          ]
        }
      },
      "id": "if_post",
      "name": "IF: ¿Es POST?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.0,
      "position": [500, 100]
    },
    {
      "parameters": {
        "jsCode": "// Extraer datos del webhook Meta\n// Meta estructura: entry[0].changes[0].value.messages[0]\n\nconst payload = $node['Verificar Token + Validar'].json.payload;\nconst messages = payload?.entry?.[0]?.changes?.[0]?.value?.messages || [];\nconst message = messages[0];\n\nif (!message) {\n  throw new Error('No message found');\n}\n\nconst from = message.from;\nconst timestamp = message.timestamp;\nconst msg_type = message.type;\n\nlet text_content = '';\nlet audio_media_id = null;\n\nif (msg_type === 'text') {\n  text_content = message.text.body || '';\n} else if (msg_type === 'audio') {\n  audio_media_id = message.audio.id;\n  text_content = '[Audio message]';\n} else if (msg_type === 'image') {\n  text_content = message.image?.caption || '[Image message]';\n} else if (msg_type === 'document') {\n  text_content = message.document?.caption || '[Document message]';\n}\n\nreturn [\n  {\n    json: {\n      phone_number: from,\n      timestamp: timestamp,\n      message_type: msg_type,\n      text_content: text_content,\n      audio_media_id: audio_media_id,\n      raw_payload: payload\n    }\n  }\n];"
      },
      "id": "extract_message",
      "name": "Code: Extraer Mensaje",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2.0,
      "position": [700, 100]
    },
    {
      "parameters": {
        "conditions": {
          "nodes": [
            {
              "name": "¿Es audio?",
              "type": "filter",
              "value1": "={{ $node['Code: Extraer Mensaje'].json.message_type }}",
              "value2": "audio"
            }
          ]
        }
      },
      "id": "if_audio",
      "name": "IF: ¿Es Audio?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.0,
      "position": [900, 100]
    },
    {
      "parameters": {
        "url": "=https://graph.instagram.com/v19.0/{{ $node['Code: Extraer Mensaje'].json.audio_media_id }}",
        "authentication": "headerBearerToken",
        "nodeCredentialType": "meta",
        "requestMethod": "GET"
      },
      "id": "download_audio_meta",
      "name": "HTTP: Descargar Audio de Meta",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [900, 250]
    },
    {
      "parameters": {
        "jsCode": "// Groq Whisper API\nconst audio_url = $node['HTTP: Descargar Audio de Meta'].json.url;\n\nif (!audio_url) {\n  throw new Error('No audio URL found');\n}\n\nreturn [\n  {\n    json: {\n      audio_url: audio_url\n    }\n  }\n];"
      },
      "id": "prepare_audio_groq",
      "name": "Code: Preparar Audio para Groq",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2.0,
      "position": [1100, 250]
