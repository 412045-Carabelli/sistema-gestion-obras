    "@types/pdfmake": "^0.2.12",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "jasmine-core": "~5.6.0",
    "json-server": "^1.0.0-beta.3",
