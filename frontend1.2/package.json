    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "@primeng/themes": "^20.2.0",
    "@tailwindcss/postcss": "^4.1.14",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.2",
    "pdfmake": "^0.2.20",
    "postcss": "^8.5.6",
    "primeicons": "^7.0.0",
    "primeng": "^19.1.4",
    "quill": "^1.3.7",
