{
  "id": null,
  "uid": "sgo-overview",
  "title": "SGO - Overview",
  "tags": ["sgo", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Up (targets)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(up)", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "HTTP Requests / min",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count[1m])) * 60", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "5xx / min",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[1m])) * 60", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "p95 Latency (s)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Rate by Service",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (application)",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate (5xx) by Service",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[1m])) by (application)",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 Latency by Service",
      "gridPos": { "x": 0, "y": 11, "w": 24, "h": 7 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (le, application))",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ]
    }
  ]
}
